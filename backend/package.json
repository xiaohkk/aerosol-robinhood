{
  "name": "aerosol-backend",
  "version": "1.0.0",
  "description": "Twitter-powered crypto payments bot + API server (Robinhood Chain)",
  "main": "dist/bot/samplebot.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/bot/samplebot.ts",
    "start": "node dist/bot/samplebot.js",
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@langchain/groq": "^0.1.2",
    "@langchain/ollama": "^0.1.0",
    "@privy-io/server-auth": "^1.18.0",
    "@supabase/supabase-js": "^2.45.0",
    "agent-twitter-client": "0.0.18",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.8",
    "patch-package": "^8.0.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4"
  }
}
